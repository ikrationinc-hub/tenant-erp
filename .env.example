# --- General ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (Postgres, apps/api) ---
# Host port is 5433, not the Postgres default 5432 (see docker/docker-compose.yml) -
# this machine already runs a native postgres on 5432 for other projects.
DATABASE_URL=postgres://hyperion:hyperion@localhost:5433/hyperion

# --- Redis (apps/api + apps/worker) ---
# Host port is 6380, not the Redis default 6379, for the same reason.
REDIS_URL=redis://localhost:6380

# --- Auth (apps/api) ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-hex-string

# --- Storage: MinIO (S3 API, apps/api) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=hyperion
S3_SECRET_ACCESS_KEY=hyperion123
S3_BUCKET=hyperion-erp

# --- SMTP: Mailhog (apps/api) ---
SMTP_HOST=localhost
SMTP_PORT=1025
