# --- General ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (Postgres, apps/api) ---
DATABASE_URL=postgres://hyperion:hyperion@localhost:5432/hyperion

# --- Redis (apps/api + apps/worker) ---
REDIS_URL=redis://localhost:6379

# --- Auth (apps/api) ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-hex-string

# --- Storage: MinIO (S3 API, apps/api) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=hyperion
S3_SECRET_ACCESS_KEY=hyperion123
S3_BUCKET=hyperion-erp

# --- SMTP: Mailhog (apps/api) ---
SMTP_HOST=localhost
SMTP_PORT=1025
