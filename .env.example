# --- General ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (Postgres, apps/api) ---
# Host port is 5433, not the Postgres default 5432 (see docker/docker-compose.yml) -
DATABASE_URL=postgres://hyperion:hyperion@localhost:5433/hyperion
# Restricted, non-superuser role - migrations create/grant it automatically (core/database/migration-runner.ts).
DATABASE_APP_URL=postgres://hyperion_app:change-me@localhost:5433/hyperion

# --- Redis (apps/api + apps/worker) ---
# Host port is 6380, not the Redis default 6379, for the same reason.
REDIS_URL=redis://localhost:6380

# --- Auth (apps/api) ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-hex-string
PLATFORM_JWT_SECRET=change-me-to-yet-another-random-64-char-hex-string

# --- Storage: MinIO (S3 API, apps/api) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=hyperion
S3_SECRET_ACCESS_KEY=hyperion123
S3_BUCKET=hyperion-erp

# --- Virus scanning: ClamAV (docker/docker-compose.yml's clamav service, apps/api) ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Email: Resend (apps/api) ---
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Hyperion ERP

# --- Web app base URL (apps/web dev server, used to build links in emails) ---
WEB_APP_BASE_URL=http://localhost:5173
