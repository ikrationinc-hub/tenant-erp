{
  "name": "@hyperion/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "lint": "eslint . && node scripts/check-search-path-boundary.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:tenant:generate": "drizzle-kit generate --config=drizzle.tenant.config.ts",
    "check:tenant-boundary": "node scripts/check-search-path-boundary.mjs"
  },
  "dependencies": {
    "@hyperion/contracts": "workspace:*",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.1.10"
  },
  "devDependencies": {
    "@hyperion/config": "workspace:*",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
